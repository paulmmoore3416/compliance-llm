# Tunables for the vLLM ROCm engine. Sourced by launch_vllm.sh.
#
# These are the values we benchmarked on a single MI300X (192 GB HBM3) with
# Llama 3.1 70B FP8. Adjust if you run on multi-GPU or constrained nodes.

PORT=8000
HOST=0.0.0.0

# Single MI300X — increase to 2/4/8 on multi-GPU nodes.
TP_SIZE=1

# 8K context handles even the longest SOP generation comfortably.
MAX_MODEL_LEN=8192

# Throughput target: 128 concurrent sequences (judges' demo + headroom).
MAX_NUM_SEQS=128

# 92% of 192 GB = ~177 GB usable; vLLM reserves the remainder for activations.
GPU_MEM_UTIL=0.92

# Let vLLM pick the right compute dtype for FP8 weights.
DTYPE=auto
