# Copy to `.env` and fill in. Never commit the populated file.

# Hugging Face — gated repo access for meta-llama/Llama-3.1-70B-Instruct
HF_TOKEN=hf_your_token_here

# Optional: Weights & Biases for training run tracking
WANDB_API_KEY=
WANDB_PROJECT=compliance-llama
WANDB_ENTITY=

# Where to mount model weights (host path)
MODEL_DIR=./models
HF_HOME=./.hf-cache

# Frontend → backend
VITE_API_BASE_URL=http://localhost:8080
