# Compliance-Llama: Training image for AMD MI300X (ROCm 6.2)
#
# Built on the official ROCm PyTorch image. The MI300X uses gfx942 (CDNA3),
# which ROCm 6.2 targets natively. Avoid any CUDA paths.

FROM rocm/pytorch:rocm6.2_ubuntu22.04_py3.10_pytorch_2.4.0

ENV DEBIAN_FRONTEND=noninteractive \
    HSA_OVERRIDE_GFX_VERSION=9.4.0 \
    PYTORCH_ROCM_ARCH=gfx942 \
    HIP_VISIBLE_DEVICES=0 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /workspace

# System deps. git-lfs is required for pulling Llama 3.1 70B weights.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git git-lfs build-essential cmake ninja-build \
        curl ca-certificates jq tmux htop vim \
    && git lfs install \
    && rm -rf /var/lib/apt/lists/*

# bitsandbytes ROCm fork. The upstream wheel is CUDA-only; ROCm support lives
# on the rocm-enabled branch and is built against HIP at install time.
RUN pip install --no-cache-dir --upgrade pip setuptools wheel \
 && pip install --no-cache-dir \
        "transformers>=4.45,<4.50" \
        "peft>=0.13.0" \
        "accelerate>=0.34.0" \
        "datasets>=3.0.0" \
        "trl>=0.11.0" \
        "sentencepiece" \
        "tiktoken" \
        "hf_transfer" \
        "huggingface_hub[cli]" \
        "wandb" \
        "tensorboard" \
        "evaluate" \
        "rouge_score" \
        "pyyaml" \
        "python-dotenv" \
 && pip install --no-cache-dir --no-build-isolation \
        "git+https://github.com/ROCm/bitsandbytes.git@rocm_enabled"

# Flash-attention for ROCm — optional but materially helps 70B throughput.
# Built from the AMD-maintained CK fork. Comment out if your image already
# ships flash-attn.
RUN pip install --no-cache-dir --no-build-isolation \
        "git+https://github.com/ROCm/flash-attention.git@main_perf" || true

COPY training/ /workspace/training/
COPY data/ /workspace/data/
COPY configs/ /workspace/configs/
COPY scripts/ /workspace/scripts/

CMD ["bash"]
